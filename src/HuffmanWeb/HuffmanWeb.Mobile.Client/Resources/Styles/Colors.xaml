<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Professional Web Palette -->
    <Color x:Key="Primary">#3F51B5</Color> <!-- Deep Indigo -->
    <Color x:Key="PrimaryDark">#303F9F</Color>
    <Color x:Key="PrimaryLight">#C5CAE9</Color>
    <Color x:Key="Secondary">#009688</Color> <!-- Teal -->
    <Color x:Key="SecondaryDark">#00796B</Color>
    <Color x:Key="Accent">#FF4081</Color> <!-- Pink Accent -->
    
    <Color x:Key="Background">#F5F7FA</Color> <!-- Light Gray Blue -->
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="Error">#B00020</Color>

    <Color x:Key="TextPrimary">#212121</Color> <!-- Dark Gray -->
    <Color x:Key="TextSecondary">#757575</Color> <!-- Medium Gray -->
    <Color x:Key="TextInverse">#FFFFFF</Color>

    <Color x:Key="Gray100">#F5F5F5</Color>
    <Color x:Key="Gray200">#EEEEEE</Color>
    <Color x:Key="Gray300">#E0E0E0</Color>
    <Color x:Key="Gray400">#BDBDBD</Color>
    <Color x:Key="Gray500">#9E9E9E</Color>
    <Color x:Key="Gray600">#757575</Color>
    <Color x:Key="Gray900">#212121</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
</ResourceDictionary>