<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="HuffmanWeb.Mobile.Client.Pages.Encode.EncodeForm"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:HuffmanWeb.Mobile.Client.Pages.Encode.Components"
    xmlns:strings="clr-namespace:HuffmanPlayground.Mobile.Client.Resources.Strings"
    Title="{x:Static strings:AppResources.EncodePageTitle}"
    HideSoftInputOnTapped="True"
    Loaded="OnPageLoaded"
    BackgroundColor="{StaticResource Background}">

    <ScrollView VerticalOptions="FillAndExpand">
        <VerticalStackLayout Padding="24" Spacing="24">

            <!-- Input Card -->
            <Border Style="{StaticResource Border}">
                <VerticalStackLayout Padding="20" Spacing="16">
                    <Label Text="Input Text" Style="{StaticResource CardTitle}" />
                    
                    <Editor x:Name="textToEncode"
                            Text="{Binding TextToEncode}"
                            Placeholder="{x:Static strings:AppResources.EncodeEditorPlaceHoler}"
                            HeightRequest="150" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16" Margin="0,8,0,0">
                        <Button x:Name="ResetBtn"
                                Text="{x:Static strings:AppResources.ResetButton}"
                                Clicked="ResetBtn_Clicked"
                                Style="{StaticResource OutlinedButton}"
                                Grid.Column="0" />
                        
                        <Button x:Name="EncodeBtn"
                                Text="{x:Static strings:AppResources.EncodeButton}"
                                Clicked="EncodeBtn_Clicked"
                                Grid.Column="1" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Results Section -->
            <ActivityIndicator IsRunning="{Binding IsWorking}"
                               IsVisible="{Binding IsWorking}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center" />

            <VerticalStackLayout Spacing="24" IsVisible="{Binding Response, Converter={StaticResource IsNotNullConverter}}"> <!-- Assuming IsNotNullConverter exists or logic handles visibility via child elements -->
                
                <!-- Stats Card -->
                <Border Style="{StaticResource Border}" IsVisible="{Binding IsVisible, Source={x:Reference encodingStats}}">
                    <VerticalStackLayout Padding="20" Spacing="12">
                        <Label Text="Statistics" Style="{StaticResource CardTitle}" />
                        <components:EncodingStatsDisplay
                            x:Name="encodingStats"
                            CompressionPercent="{Binding CompressionPercent}"
                            EncodedSize="{Binding Response.EncodedSize}"
                            OriginalSize="{Binding Response.OriginalSize}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Binary String Card -->
                <Border Style="{StaticResource Border}" IsVisible="{Binding IsVisible, Source={x:Reference binaryString}}">
                    <VerticalStackLayout Padding="20" Spacing="12">
                        <Label Text="Encoded Binary" Style="{StaticResource CardTitle}" />
                        <components:HuffmanBinaryString
                            x:Name="binaryString"
                            HuffmanString="{Binding Response.EncodedBinaryString}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Actions Card -->
                <Border Style="{StaticResource Border}">
                    <VerticalStackLayout Padding="20" Spacing="16">
                        <Label Text="Actions" Style="{StaticResource CardTitle}" />
                        
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="16">
                            <Button x:Name="MatchingTablebtn"
                                    Text="{x:Static strings:AppResources.MatchingTableButton}"
                                    Clicked="MatchingTablebtn_Clicked"
                                    Style="{StaticResource OutlinedButton}"
                                    Grid.Row="0" Grid.Column="0" />
                            
                            <Button x:Name="TreeBtn"
                                    Text="{x:Static strings:AppResources.TreeButton}"
                                    Clicked="TreeBtn_Clicked"
                                    Style="{StaticResource OutlinedButton}"
                                    Grid.Row="0" Grid.Column="1" />
                            
                            <Button x:Name="copyToDecodeBtn"
                                    Text="{x:Static strings:AppResources.CopytoDecodePageButton}"
                                    Clicked="copyToDecodeBtn_Clicked"
                                    Grid.Row="1" Grid.ColumnSpan="2" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
