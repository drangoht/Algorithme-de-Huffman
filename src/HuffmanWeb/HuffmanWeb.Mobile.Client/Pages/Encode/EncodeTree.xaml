<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="HuffmanWeb.Mobile.Client.Pages.Encode.EncodeTree"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:HuffmanWeb.Mobile.Client.Components"
    xmlns:controls="clr-namespace:Maui.ColorPicker;assembly=Maui.ColorPicker"
    xmlns:drawables="clr-namespace:HuffmanWeb.Mobile.Client.Components.BinaryTree"
    xmlns:strings="clr-namespace:HuffmanPlayground.Mobile.Client.Resources.Strings"
    Title="{x:Static strings:AppResources.EncodeTreePageTitle}"
    BackgroundColor="{StaticResource Background}">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            x:Name="settingsToolsBarItem"
            Clicked="settingsToolsBarItem_Clicked"
            Text="{x:Static strings:AppResources.TreeSettingsLabel}" />
    </ContentPage.ToolbarItems>

    <Grid>
        <!-- Main Content (Tree) -->
        <ScrollView>
            <drawables:BinaryTreeDrawable
                x:Name="binaryTree"
                Graph="{Binding ViewModel.Response.Graph}"
                HeightRequest="2000"
                NodeHeight="20"
                NodeWidth="40"
                WidthRequest="2000"
                BackgroundColor="Transparent">
                <drawables:BinaryTreeDrawable.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnPanUpdated" />
                </drawables:BinaryTreeDrawable.GestureRecognizers>
            </drawables:BinaryTreeDrawable>
        </ScrollView>

        <!-- Settings Panel (Overlay) -->
        <Border x:Name="settingsGrid"
                IsVisible="False"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource Gray300}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 12"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="16"
                Padding="16"
                WidthRequest="320"
                Shadow="{StaticResource Shadow}">
            
            <VerticalStackLayout Spacing="16">
                <Label Text="Tree Settings" Style="{StaticResource CardTitle}" />

                <!-- Dimensions -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static strings:AppResources.TreeNodeWidthSettingLabel}" Style="{StaticResource LabelConfigTree}" />
                    <Slider x:Name="nodewidth"
                            Maximum="150" Minimum="30"
                            Value="{Binding TreeViewModel.NodeWidth}"
                            ValueChanged="nodewidth_ValueChanged" />
                    
                    <Label Text="{x:Static strings:AppResources.TreeNodeHeightSettingLabel}" Style="{StaticResource LabelConfigTree}" />
                    <Slider x:Name="nodeHeight"
                            Maximum="150" Minimum="30"
                            Value="{Binding TreeViewModel.NodeHeight}"
                            ValueChanged="nodeHeight_ValueChanged" />
                </VerticalStackLayout>

                <!-- Colors -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static strings:AppResources.TreeNodeColorSettingLabel}" Style="{StaticResource LabelConfigTree}" />
                    <controls:ColorPicker x:Name="NodeColor"
                                          PickedColor="{Binding TreeViewModel.NodeColor}"
                                          PickedColorChanged="NodeColor_PickedColorChanged"
                                          ColorFlowDirection="Horizontal"
                                          ColorSpectrumStyle="ShadeToHueStyle"
                                          HeightRequest="100" />

                    <Label Text="{x:Static strings:AppResources.TreeNodeLabelColorSettingLabel}" Style="{StaticResource LabelConfigTree}" />
                    <controls:ColorPicker x:Name="NodeTextColor"
                                          PickedColor="{Binding TreeViewModel.NodeTextColor}"
                                          PickedColorChanged="NodeTextColor_PickedColorChanged"
                                          ColorFlowDirection="Horizontal"
                                          ColorSpectrumStyle="ShadeToHueStyle"
                                          HeightRequest="100" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>