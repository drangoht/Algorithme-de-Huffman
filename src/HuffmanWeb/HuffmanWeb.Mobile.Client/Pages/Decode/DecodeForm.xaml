<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="HuffmanWeb.Mobile.Client.Pages.Decode.DecodeForm"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:strings="clr-namespace:HuffmanPlayground.Mobile.Client.Resources.Strings"
    Title="{x:Static strings:AppResources.DecodePageTitle}"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">

            <!-- Input Card -->
            <Border Style="{StaticResource Border}">
                <VerticalStackLayout Padding="20" Spacing="16">
                    <Label Text="Input Data" Style="{StaticResource CardTitle}" />
                    
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Encrypted Text" TextColor="{StaticResource TextSecondary}" FontSize="14" />
                        <Editor x:Name="textToDecode"
                                Text="{Binding TextToDecode}"
                                Placeholder="{x:Static strings:AppResources.DecodeTextEditorPlaceHoler}"
                                HeightRequest="100" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Matching Table (JSON)" TextColor="{StaticResource TextSecondary}" FontSize="14" />
                        <Editor x:Name="matchingTableJson"
                                Text="{Binding MatchingTableJson}"
                                Placeholder="{x:Static strings:AppResources.DecodeMatchingTableJsonPlaceHolder}"
                                HeightRequest="100" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16" Margin="0,8,0,0">
                        <Button x:Name="ResetBtn"
                                Text="{x:Static strings:AppResources.ResetButton}"
                                Clicked="ResetBtn_Clicked"
                                Style="{StaticResource OutlinedButton}"
                                Grid.Column="0" />
                        
                        <Button x:Name="DecodeBtn"
                                Text="{x:Static strings:AppResources.DecodeButton}"
                                Clicked="DecodeBtn_Clicked"
                                Grid.Column="1" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Output Card -->
            <Border Style="{StaticResource Border}">
                <VerticalStackLayout Padding="20" Spacing="16">
                    <Label Text="Result" Style="{StaticResource CardTitle}" />
                    
                    <Editor x:Name="decodedText"
                            Text="{Binding Response.DecodedText}"
                            Placeholder="{x:Static strings:AppResources.DecodeResultEditorPlaceHolder}"
                            IsReadOnly="True"
                            HeightRequest="120"
                            BackgroundColor="{StaticResource Background}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>